# LODESTAR environment — copy to .env (gitignored) and fill in.
# Only non-secret configuration belongs here. Secrets (API keys, tokens,
# webhook URLs) are stored via the OS keychain (Electron safeStorage), never
# in .env or the repo (SSOT §4.6).

# Runtime data directory (DB, logs, encrypted secrets, ML/voice models).
# Defaults to Electron's userData path. Set this to keep large runtime data off
# the system drive. Must be a LOCAL ABSOLUTE path — UNC paths (\\host\share)
# are refused. On this build machine the operator runs data on D: (SSOT §3.1).
LODESTAR_DATA_DIR=D:\lodestar-data

# Electron binary download cache (install-time only; keeps the ~140MB binary
# off C: on constrained machines). Consumed by @electron/get during install.
ELECTRON_CACHE=D:\lodestar-data\.electron-cache

# Disable Turborepo anonymous telemetry in CI (SSOT §Step 0.1).
TURBO_TELEMETRY_DISABLED=1
